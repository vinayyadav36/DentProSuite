# ─── Node Environment ───────────────────────────────
NODE_ENV=development
PORT=3001

# ─── JWT Secret (REQUIRED - CHANGE IN PRODUCTION!) ──
JWT_SECRET=super-secret-local-dev-key

# ─── Frontend URL (for CORS) ────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Storage Mode ────────────────────────────────────
# Options: local | appwrite
STORAGE_MODE=local

# ─── Appwrite Cloud DB Mode ──────────────────────────
# Uncomment and fill to use Appwrite instead of local JSON files
# STORAGE_MODE=appwrite
# APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
# APPWRITE_PROJECT_ID=
# APPWRITE_API_KEY=
# APPWRITE_DATABASE_ID=
