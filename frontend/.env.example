# ─── Backend API URL ─────────────────────────────────
VITE_API_URL="http://localhost:3001"

# ─── Router History Mode ─────────────────────────────
# Set to "true" for hash-based routing (useful for some deployments)
# VITE_USE_HASH_HISTORY="false"

# ─── Appwrite Client SDK (Optional) ──────────────────
# Uncomment to enable Appwrite client-side flows
# VITE_APPWRITE_ENDPOINT="https://cloud.appwrite.io/v1"
# VITE_APPWRITE_PROJECT_ID=""
# VITE_APPWRITE_DATABASE_ID=""
